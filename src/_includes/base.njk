<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title and title != "Journal" %}{{ title }} — {% endif %}StationSixADV</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="site-header">
    <a href="/" class="site-name">StationSixADV</a>
    <nav class="site-nav" aria-label="Primary">
      <a href="/" {% if page.url == '/' or page.url.startsWith('/posts/') %}aria-current="page"{% endif %}>Journal</a>
      <a href="/about/" {% if page.url == '/about/' %}aria-current="page"{% endif %}>About</a>
    </nav>
  </header>

  <main class="site-main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>StationSixADV</p>
    <nav class="social-nav" aria-label="Social">
      <a href="https://www.instagram.com/stationsix/" target="_blank" rel="noopener">Instagram</a>
      <span class="post-item-sep">·</span>
      <a href="https://www.facebook.com/stationsix" target="_blank" rel="noopener">Facebook</a>
    </nav>
  </footer>

</body>
</html>
